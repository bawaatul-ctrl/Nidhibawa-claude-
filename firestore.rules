rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "bawa.atul@gmail.com");
    }

    function isEnrolledClient(enrollmentId) {
      let enrollment = get(/databases/$(database)/documents/enrollments/$(enrollmentId)).data;
      return isAuthenticated() && enrollment.userId == request.auth.uid;
    }

    // ─────────────────────────────────────────────
    // USERS
    // ─────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) &&
                    request.resource.data.keys().hasAll(['uid', 'email']) &&
                    (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) &&
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    // ─────────────────────────────────────────────
    // ENROLLMENTS — one per client per program
    // ─────────────────────────────────────────────

    match /enrollments/{enrollmentId} {
      // Client reads their own; admin reads all
      allow read: if isAuthenticated() &&
                  (resource.data.userId == request.auth.uid || isAdmin());
      // Admin creates enrollments (after payment confirmed)
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // SESSION NOTES — per session within an enrollment
    // ─────────────────────────────────────────────

    match /sessionNotes/{noteId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      // Clients write their own exercise answers
      allow create: if isAuthenticated() &&
                    request.resource.data.userId == request.auth.uid;
      // Clients update their own exercises; admin updates everything (adds coach notes)
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientExercises', 'updatedAt']))
        || isAdmin()
      );
    }

    // ─────────────────────────────────────────────
    // PROGRAMS — public metadata for website display
    // ─────────────────────────────────────────────

    match /programs/{programId} {
      allow read: if true; // Public
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // PAYMENTS — audit trail, admin only writes
    // ─────────────────────────────────────────────

    match /payments/{paymentId} {
      allow read: if isAuthenticated() &&
                  (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // BOOKINGS — existing schema kept
    // ─────────────────────────────────────────────

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() &&
                  (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
                    request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() &&
                    (resource.data.uid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
